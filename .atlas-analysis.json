  "keyFeatures": [
    "Create and share study plans with curated resources",
    "Multi-source resource integration (YouTube, PDFs, articles)",
    "Instance-based progress tracking with dual metrics",
    "Collaborative editing with role-based access control",
    "Smart email notifications and deadline reminders",
    "Global resource pool with de-duplication",
    "Beautiful gradient-based UI with dark mode support",
    "Firebase authentication with MongoDB storage"
  ],
  "publicApiSurface": [
    "GET /api/study-plans - List study plans",
    "POST /api/study-plans - Create study plan",
    "GET /api/study-plans/:id - Get study plan details",
    "PUT /api/study-plans/:id - Update study plan",
    "DELETE /api/study-plans/:id - Delete study plan",
    "POST /api/study-plans/:id/share - Share plan with collaborator",
    "GET /api/instances - Get user instances",
    "POST /api/instances - Create instance from plan",
    "GET /api/instances/:id - Get instance details",
    "PUT /api/instances/:id - Update instance",
    "DELETE /api/instances/:id - Delete instance",
    "POST /api/resources - Create or get resource",
    "GET /api/resources/:id - Get resource details",
    "GET /api/resources/bulk - Get multiple resources",
    "GET /api/user-progress - Get user progress",
    "POST /api/user-progress - Toggle resource completion",
    "GET /api/users/me - Get current user",
    "GET /api/notifications/settings - Get notification settings",
    "PUT /api/notifications/settings - Update notification settings"
  ]
